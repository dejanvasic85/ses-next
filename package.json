{
  "scripts": {
    "dev": "turbo dev",
    "dev:content": "npm run dev -w ses-content",
    "format": "prettier --write .",
    "type:check": "turbo type:check",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint-staged": "lint-staged",
    "deploy:content": "npm run build -w ses-content && npm run deploy -w ses-content",
    "update:rating": "npm run update:rating -w ses-reviews",
    "update:reviews": "npm run update:reviews -w ses-reviews",
    "prepare": "husky"
  },
  "workspaces": [
    "./packages/*"
  ],
  "volta": {
    "node": "24.14.0"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "turbo": "2.8.14"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier . --write",
      "npm run lint -w ses-next"
    ]
  },
  "packageManager": "npm@11.11.0"
}
