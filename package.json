{
  "scripts": {
    "dev": "turbo dev",
    "dev:content": "pnpm --filter ses-content dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type:check": "turbo type:check",
    "test:e2e": "turbo test:e2e",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "lint-staged": "lint-staged",
    "ci": "turbo ci",
    "deploy:content": "pnpm --filter ses-content build && pnpm --filter ses-content deploy",
    "update:rating": "pnpm --filter ses-reviews update:reviews",
    "update:reviews": "pnpm --filter ses-reviews update:reviews",
    "prepare": "husky"
  },
  "volta": {
    "node": "24.15.0"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "next": "16.2.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "turbo": "2.9.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier . --write",
      "pnpm --filter ses-next lint"
    ]
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "aws-sdk",
      "esbuild",
      "puppeteer",
      "sharp",
      "unrs-resolver"
    ]
  }
}
