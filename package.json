{
  "scripts": {
    "dev": "turbo dev",
    "dev:content": "npm run dev -w ses-content",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type:check": "turbo type:check",
    "test:e2e": "turbo test:e2e",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "lint-staged": "lint-staged",
    "ci": "turbo ci",
    "deploy:content": "npm run build -w ses-content && npm run deploy -w ses-content",
    "update:rating": "npm run update:rating -w ses-reviews",
    "update:reviews": "npm run update:reviews -w ses-reviews",
    "prepare": "husky"
  },
  "workspaces": [
    "./packages/*"
  ],
  "volta": {
    "node": "24.14.1"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "turbo": "2.9.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier . --write",
      "npm run lint -w ses-next"
    ]
  },
  "packageManager": "npm@11.12.1"
}
