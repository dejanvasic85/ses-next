{
  "scripts": {
    "dev": "turbo dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type:check": "turbo type:check",
    "test:e2e": "turbo test:e2e",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "lint-staged": "lint-staged",
    "ci": "turbo ci",
    "deploy:content": "pnpm --filter ses-content build && pnpm --filter ses-content run deploy",
    "update:rating": "pnpm --filter ses-reviews update:reviews",
    "update:reviews": "pnpm --filter ses-reviews update:reviews",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "next": "16.2.7",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "turbo": "2.9.16"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier . --write",
      "pnpm --filter ses-next lint"
    ]
  },
  "packageManager": "pnpm@11.5.2"
}
