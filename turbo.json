{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "SES_AWS_ACCESS_KEY_ID",
        "SES_AWS_SECRET_ACCESS_KEY",
        "EMAIL_ENABLED",
        "EMAIL_FROM",
        "EMAIL_TO",
        "GTM_ID",
        "NEXT_PUBLIC_GTM_ID",
        "RECAPTCHA_SITE_KEY",
        "NEXT_PUBLIC_RECAPTCHA_SITE_KEY",
        "RECAPTCHA_SECRET_KEY",
        "RECAPTCHA_BYPASS"
      ]
    },
    "ci": {
      "dependsOn": ["lint", "type:check", "format:check"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"],
      "cache": false
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "cache": false
    },
    "type:check": {
      "dependsOn": ["^type:check"],
      "cache": false
    },
    "format:check": {
      "dependsOn": ["^format:check"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["^test:e2e"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": true
    },
    "dev:content": {
      "dependsOn": ["^dev:content"],
      "cache": false,
      "persistent": true
    }
  }
}
